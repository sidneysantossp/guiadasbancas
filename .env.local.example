# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Evolution API (WhatsApp)
EVOLUTION_API_URL=https://sua-evolution-api.com
EVOLUTION_API_KEY=sua-api-key-aqui
EVOLUTION_INEXTAUTH_SECRET=

# Habilita o reset de senha local (sem SMTP) para a rota /api/admin/reset-password
# Use apenas em DEV. Em produção mantenha como false ou remova.
ALLOW_LOCAL_RESET=true

# URL pública do app (para redirects de email do Supabase)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Mercos (produção)
MERCOS_API_URL=https://app.mercos.com/api/v1
MERCOS_APPLICATION_TOKEN=
MERCOS_COMPANY_TOKEN=

# Mercos Sandbox (para homologação)
MERCOS_SANDBOX_API_URL=https://sandbox.mercos.com/api/v1
MERCOS_SANDBOX_APPLICATION_TOKEN=d39001ac-0b14-11f0-8ed7-6e1485be00f2
MERCOS_SANDBOX_COMPANY_TOKEN=4b866744-a086-11f0-ada6-5e65486a6283

# Asaas
# Chave de API do Asaas. Em produção, use chave de produção.
ASAAS_API_KEY=
ASAAS_ENVIRONMENT=production
# Token configurado no webhook do Asaas. Obrigatório em produção para /api/webhooks/asaas.
ASAAS_WEBHOOK_TOKEN=

# Gateway de cobrança para novas mensalidades: asaas ou cora
PAYMENT_GATEWAY=asaas

# Cora - integração direta com mTLS
CORA_ENVIRONMENT=stage
CORA_CLIENT_ID=
# Aceita PEM com quebras de linha reais, \n escapado, ou base64 do PEM.
CORA_CERTIFICATE=
CORA_PRIVATE_KEY=
CORA_WEBHOOK_TOKEN=

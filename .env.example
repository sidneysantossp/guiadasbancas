# Database (quando implementar)
# DATABASE_URL=postgresql://user:password@localhost:5432/guiadasbancas

# Email (quando implementar)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# Analytics (quando implementar)
# GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
# FACEBOOK_PIXEL_ID=123456789

# Payment Gateway (quando implementar)
# MERCADOPAGO_ACCESS_TOKEN=your-token
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# ASAAS_API_KEY=sua-chave-do-asaas
# ASAAS_ENVIRONMENT=production
# ASAAS_WEBHOOK_TOKEN=configure-o-mesmo-token-no-painel-do-asaas
# PAYMENT_GATEWAY=asaas
# CORA_ENVIRONMENT=stage
# CORA_CLIENT_ID=seu-client-id-cora
# CORA_CERTIFICATE=certificado-pem-ou-base64
# CORA_PRIVATE_KEY=private-key-pem-ou-base64
# CORA_WEBHOOK_TOKEN=token-compartilhado-do-webhook

# Image Storage
# Mantem Supabase por padrão. Use cloudflare_r2 para enviar novos uploads ao Cloudflare R2.
# IMAGE_STORAGE_PROVIDER=supabase
# IMAGE_STORAGE_FALLBACK_TO_SUPABASE=true
# CLOUDFLARE_R2_ACCOUNT_ID=seu-account-id
# CLOUDFLARE_R2_ACCESS_KEY_ID=sua-access-key
# CLOUDFLARE_R2_SECRET_ACCESS_KEY=sua-secret-key
# CLOUDFLARE_R2_BUCKET=guiadasbancas-images
# CLOUDFLARE_R2_PUBLIC_URL=https://imagens.seudominio.com
